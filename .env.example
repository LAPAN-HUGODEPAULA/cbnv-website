# ── Geral ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=                    # Obrigatório. Gerar com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SETTINGS_MODULE=cbnv.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=True                             # Definir como False em produção
BASE_URL=http://localhost:8000
WAGTAILADMIN_BASE_URL=http://localhost:8001
DJANGO_LOG_LEVEL=INFO

# ── Banco de Dados ────────────────────────────────────────────────────
POSTGRES_DB=cbnv
POSTGRES_USER=cbnv
POSTGRES_PASSWORD=                     # Obrigatório em produção
DB_HOST=localhost
DB_PORT=5432

# ── SMTP / Email ──────────────────────────────────────────────────────
SMTP_HOST=                             # Obrigatório em produção (ex: smtp.gmail.com)
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=                             # Obrigatório em produção
SMTP_PASSWORD=                         # Obrigatório em produção
DEFAULT_FROM_EMAIL=cbnv2026@cbnv.org.br

# ── SSL / TLS ─────────────────────────────────────────────────────────
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem  # Caminho do certificado SSL no container nginx
SSL_KEY_PATH=/etc/nginx/ssl/key.pem    # Caminho da chave privada SSL no container nginx

# ── Gunicorn ──────────────────────────────────────────────────────────
GUNICORN_WORKERS=4                     # Número de workers (padrão: 4)
GUNICORN_TIMEOUT=120                   # Timeout em segundos (padrão: 120)
GUNICORN_LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────────────────
NGINX_RATE_LIMIT=10r/s                 # Limite de requisições por IP (padrão: 10r/s)
NGINX_BURST=20                         # Burst permitido (padrão: 20)

# ── Segurança (django-axes) ──────────────────────────────────────────
AXES_FAILURE_LIMIT=5                   # Tentativas de login antes do lockout (padrão: 5)
AXES_COOLOFF_TIME=15                   # Tempo de lockout em minutos (padrão: 15)

# ── Backups ───────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7                # Dias de retenção dos backups (padrão: 7)
