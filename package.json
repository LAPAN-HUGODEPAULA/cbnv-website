{
  "name": "cbnv-website",
  "version": "1.0.0",
  "description": "12o Congresso Brasileiro de Neurociências da Visão",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tailwindcss --input src/input.css --output static/css/output.css --minify",
    "watch": "tailwindcss --input src/input.css --output static/css/output.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --project=chromium --grep @a11y",
    "audit:perf": "lighthouse http://localhost:8000 --output html --output-path ./reports/lighthouse.html"
  },
