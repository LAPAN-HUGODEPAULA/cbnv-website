  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.4",
    "lighthouse": "^13.2.0",
    "playwright": "^1.59.1",
